// 4. robin karp

class Solution {
public:
    int strStr(string haystack, string needle) {
        int n = haystack.length(), m = needle.length();
        if (m > n) return -1;

        long long needleHash = 0, windowHash = 0, power = 1, mod = 1e9+7;
        for (int i = 0; i < m; i++) {
            needleHash = (needleHash * 31 + needle[i]) % mod;
            windowHash = (windowHash * 31 + haystack[i]) % mod;
            if (i > 0) power = (power * 31) % mod;
        }

        for (int i = 0; i <= n - m; i++) {
            if (needleHash == windowHash) {
                if (haystack.substr(i, m) == needle) return i; // Final check
            }
            if (i < n - m) {
                // Roll the hash: remove first char, add next char
                windowHash = (windowHash - haystack[i] * power) % mod;
                windowHash = (windowHash * 31 + haystack[i + m]) % mod;
                if (windowHash < 0) windowHash += mod; // Handle negative results
            }
        }
        return -1;
    }
};
